# Copy this file to `.env` and fill in your real Supabase values.
# `.env` is gitignored; this `.env.example` is committed as documentation.

# Safe to expose in the browser (these get bundled into the client):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — admin access, bypasses Row Level Security.
# Used ONLY by local scripts (e.g. scripts/seed.js). Never prefix with VITE_,
# never deploy to Vercel, never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-LOCAL-ONLY
